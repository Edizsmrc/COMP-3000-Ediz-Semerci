{
  "manifest_version": 3,
  "name": "PhishGuard AI for Gmail",
  "version": "2.0.0",
  "description": "AI-enhanced Gmail phishing detection using a locally scored machine learning model and explainable link analysis.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://mail.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishGuard AI"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "mlModel.js",
        "rules.js",
        "contentScript.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}